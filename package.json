{
  "name": "xps-intelligence-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:worker": "pnpm --filter worker dev",
    "docker:up": "docker compose -f infra/docker/compose.local.yml up -d --build",
    "docker:down": "docker compose -f infra/docker/compose.local.yml down",
    "docker:logs": "docker compose -f infra/docker/compose.local.yml logs --tail=200",
    "playwright:install": "pnpm exec playwright install --with-deps chromium",
    "test:e2e": "node tests/scripts/run-e2e.mjs",
    "benchmark:e2e": "node tests/scripts/run-benchmark.mjs",
    "validate:headful": "node tests/scripts/run-headed-validation.mjs",
    "test:chaos": "node tests/scripts/run-chaos.mjs",
    "smoke:postdeploy": "node tests/scripts/run-smoke.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "playwright": "^1.58.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
